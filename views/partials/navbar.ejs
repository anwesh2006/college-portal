                    </li>

                    <!-- Student links -->
                    <% if (locals.user.role==='student' ) { %>
                        <li class="nav-item">
                            <a class="nav-link" href="/student/dashboard">Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/courses">Courses</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/student/grades">My Grades</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/student/assignments">Assignments</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/student/profile">Profile</a>
                        </li>
                        <% } %>

                            <!-- Faculty links -->
                            <% if (locals.user.role==='faculty' ) { %>
                                <li class="nav-item">
                                    <a class="nav-link" href="/faculty/dashboard">Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" href="/courses">Courses</a>
                                </li>
                                <% } %>

                                    <!-- Admin links -->
                                    <% if (locals.user.role==='admin' ) { %>
                                        <li class="nav-item">
                                            <a class="nav-link" href="/admin/panel">Dashboard</a>
                                        </li>
                                        <li class="nav-item">
                                            <a class="nav-link" href="/admin/users">Manage Users</a>
                                        </li>
                                        <li class="nav-item">
                                            <a class="nav-link" href="/courses">Courses</a>
                                        </li>
                                        <li class="nav-item">
                                            <a class="nav-link" href="/admin/reports">Reports</a>
                                        </li>
                                        <% } %>

                                            <!-- Dark mode toggle -->
                                            <li class="nav-item ms-lg-2 mt-2 mt-lg-0">
                                                <button class="dark-mode-toggle" id="darkModeToggle" title="Toggle dark mode">
                                                    <i class="bi bi-moon-fill" id="darkModeIcon"></i>
                                                    <span id="darkModeLabel">Dark</span>
                                                </button>
                                            </li>

                                            <!-- Logout button -->
                                            <li class="nav-item ms-lg-2 mt-2 mt-lg-0">
                                                <a class="nav-link btn btn-outline-light btn-sm"
                                                    href="/auth/logout">Logout</a>
                                            </li>

                                            <% } else { %>
                                                <!-- Dark mode toggle (logged out) -->
                                                <li class="nav-item ms-lg-2 mt-2 mt-lg-0">
                                                    <button class="dark-mode-toggle" id="darkModeToggle" title="Toggle dark mode">
                                                        <i class="bi bi-moon-fill" id="darkModeIcon"></i>
                                                        <span id="darkModeLabel">Dark</span>
