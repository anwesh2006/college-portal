<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= course.title %> - Manage Course</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        * { font-family: 'Inter', sans-serif; }
        body { background: #f0f2f5; }
        .page-header { background: linear-gradient(135deg, #4f8cff, #6c5ce7); color: white; padding: 40px 0; margin-bottom: 30px; }
        .page-title { font-weight: 700; margin-bottom: 10px; }
        .table-container { background: white; padding: 24px; border-radius: 12px; box-shadow: 0 1px 6px rgba(0,0,0,0.06); border: 1px solid #e8ecf1; }
        .nav-tabs .nav-link { font-weight: 500; color: #555; }
        .nav-tabs .nav-link.active { color: #4f8cff; font-weight: 600; border-bottom: 3px solid #4f8cff; }
        .assignment-card { border-left: 4px solid #4f8cff; transition: transform 0.15s; }
        .assignment-card:hover { transform: translateY(-2px); }
        .assignment-card.overdue { border-left-color: #e74c3c; }
        /* Dark mode overrides for this page */
        body.dark-mode { background: #1a1d23 !important; }
        body.dark-mode .table-container { background: #242830; border-color: #353a44; }
        body.dark-mode .nav-tabs { border-color: #353a44; }
        body.dark-mode .nav-tabs .nav-link { color: #aaa; }
        body.dark-mode .nav-tabs .nav-link.active { color: #8bb8ff; border-bottom-color: #8bb8ff; }
    </style>
    <script>if(localStorage.getItem('eduportal-dark-mode')==='true'){document.documentElement.classList.add('dark-mode');}</script>
</head>
<body>
<script>if(localStorage.getItem('eduportal-dark-mode')==='true'){document.body.classList.add('dark-mode');}</script>

    <%- include('../partials/navbar') %>

    <div class="page-header">
        <div class="container">
            <h1 class="page-title"><%= course.title %> (<%= course.code %>)</h1>
            <p class="mb-0 fs-5 opacity-75">Department: <%= course.department %> | Schedule: <%= course.schedule || 'TBA' %></p>
            <div class="mt-3">
                <a href="/faculty/dashboard" class="btn btn-light btn-sm"><i class="bi bi-arrow-left me-1"></i>Back to Dashboard</a>
                <a href="/courses" class="btn btn-outline-light btn-sm ms-2"><i class="bi bi-grid me-1"></i>All Courses</a>
            </div>
        </div>
    </div>

    <div class="container mb-5">

        <!-- Stats -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card shadow-sm border-0 border-start border-primary border-4">
                    <div class="card-body py-3">
                        <h6 class="text-muted text-uppercase mb-1" style="font-size:0.75rem;letter-spacing:1px;">Students</h6>
                        <h2 class="mb-0 text-primary"><%= totalEnrolled %> / <%= course.totalSlots %></h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-0 border-start border-success border-4">
                    <div class="card-body py-3">
                        <h6 class="text-muted text-uppercase mb-1" style="font-size:0.75rem;letter-spacing:1px;">Credits</h6>
                        <h2 class="mb-0 text-success"><%= course.credits %></h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-0 border-start border-info border-4">
                    <div class="card-body py-3">
                        <h6 class="text-muted text-uppercase mb-1" style="font-size:0.75rem;letter-spacing:1px;">Assignments</h6>
                        <h2 class="mb-0 text-info"><%= assignments.length %></h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-0 border-start border-warning border-4">
                    <div class="card-body py-3">
                        <h6 class="text-muted text-uppercase mb-1" style="font-size:0.75rem;letter-spacing:1px;">Status</h6>
                        <h2 class="mb-0 text-warning"><%= course.isActive ? 'Active' : 'Inactive' %></h2>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabs -->
        <ul class="nav nav-tabs mb-4" id="courseTabs">
            <li class="nav-item">
                <a class="nav-link active" data-bs-toggle="tab" href="#students"><i class="bi bi-people me-1"></i>Students & Grades</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" data-bs-toggle="tab" href="#assignments"><i class="bi bi-journal-text me-1"></i>Assignments (<%= assignments.length %>)</a>
            </li>
        </ul>

        <div class="tab-content">

            <!-- TAB: Students & Grades -->
            <div class="tab-pane fade show active" id="students">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4 class="mb-0">Student Roster</h4>
                    <input type="text" id="rosterSearch" class="form-control form-control-sm" placeholder="Search..." style="width:250px;">
                </div>

                <div class="table-container">
                    <% if (enrollments.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Roll #</th>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Dept</th>
                                    <th>Sem</th>
                                    <th>Grade</th>
                                    <th>Marks</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% enrollments.forEach(enrollment => { %>
                                <% if (enrollment.studentId) { %>
                                <% const s = enrollment.studentId; %>
                                <% const existingGrade = s.grades ? s.grades.find(g => g.courseId && g.courseId.toString() === course._id.toString()) : null; %>
                                <tr class="student-row" id="student-row-<%= s._id %>">
                                    <td><span class="badge bg-secondary"><%= s.rollNumber || '—' %></span></td>
                                    <td class="fw-medium student-name"><%= s.userId ? s.userId.name : 'Unknown' %></td>
                                    <td class="text-muted student-email" style="font-size:0.85rem;"><%= s.userId ? s.userId.email : '—' %></td>
                                    <td><%= s.department || '—' %></td>
                                    <td><%= s.semester || '—' %></td>
                                    <td>
                                        <select class="form-select form-select-sm grade-select" data-student="<%= s._id %>" style="width:80px;">
                                            <option value="">—</option>
                                            <% ['A+','A','A-','B+','B','B-','C+','C','C-','D','F'].forEach(g => { %>
                                                <option value="<%= g %>" <%= existingGrade && existingGrade.grade === g ? 'selected' : '' %>><%= g %></option>
                                            <% }); %>
                                        </select>
                                    </td>
                                    <td>
                                        <input type="number" class="form-control form-control-sm marks-input" data-student="<%= s._id %>"
                                            value="<%= existingGrade ? existingGrade.marks : '' %>" min="0" max="100" style="width:70px;" placeholder="—">
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-primary save-grade-btn" data-student="<%= s._id %>">
                                            <i class="bi bi-check2"></i> Save
                                        </button>
                                        <span class="grade-status ms-1" id="status-<%= s._id %>"></span>
                                    </td>
                                </tr>
                                <% } %>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                    <% } else { %>
                    <div class="text-center py-5">
                        <i class="bi bi-people text-muted" style="font-size:3rem;"></i>
                        <h5 class="mt-3">No Students Enrolled</h5>
                    </div>
                    <% } %>
                </div>
            </div>

            <!-- TAB: Assignments -->
            <div class="tab-pane fade" id="assignments">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4 class="mb-0">Assignments</h4>
                    <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#createAssignmentModal">
                        <i class="bi bi-plus-circle me-1"></i>New Assignment
                    </button>
                </div>

                <% if (assignments.length > 0) { %>
                <div class="row">
                    <% assignments.forEach(a => { %>
                    <% const isOverdue = new Date(a.dueDate) < new Date(); %>
                    <% const sc = submissionCounts[a._id.toString()] || { count: 0, graded: 0 }; %>
                    <div class="col-md-6 mb-3">
                        <div class="card shadow-sm assignment-card <%= isOverdue ? 'overdue' : '' %>">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start">
                                    <h5 class="card-title mb-1"><%= a.title %></h5>
                                    <span class="badge <%= isOverdue ? 'bg-danger' : 'bg-success' %>">
                                        <%= isOverdue ? 'Past Due' : 'Active' %>
                                    </span>
                                </div>
                                <p class="text-muted mb-2" style="font-size:0.85rem;"><%= a.description || 'No description' %></p>
                                <div class="d-flex gap-3 mb-2" style="font-size:0.85rem;">
                                    <span><i class="bi bi-calendar me-1"></i>Due: <strong><%= new Date(a.dueDate).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></strong></span>
                                    <span><i class="bi bi-star me-1"></i>Total: <strong><%= a.totalMarks %></strong> marks</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span style="font-size:0.85rem;">
                                        <i class="bi bi-file-earmark-arrow-up me-1"></i>
                                        <strong><%= sc.count %></strong> submitted · <strong><%= sc.graded %></strong> graded
                                    </span>
                                    <a href="/faculty/assignments/<%= a._id %>/submissions" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye me-1"></i>View Submissions
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% }); %>
                </div>
                <% } else { %>
                <div class="table-container text-center py-5">
                    <i class="bi bi-journal-x text-muted" style="font-size:3rem;"></i>
                    <h5 class="mt-3">No Assignments Yet</h5>
                    <p class="text-muted">Click "New Assignment" to create one.</p>
                </div>
                <% } %>
            </div>
        </div>
    </div>

    <!-- Create Assignment Modal -->
    <div class="modal fade" id="createAssignmentModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form action="/faculty/courses/<%= course._id %>/assignments" method="POST">
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Create Assignment</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label fw-medium">Title *</label>
                            <input type="text" name="title" class="form-control" required placeholder="e.g. Lab Assignment 1">
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-medium">Description</label>
                            <textarea name="description" class="form-control" rows="3" placeholder="Instructions or details..."></textarea>
                        </div>
                        <div class="row">
                            <div class="col-6 mb-3">
                                <label class="form-label fw-medium">Due Date *</label>
                                <input type="date" name="dueDate" class="form-control" required>
                            </div>
                            <div class="col-6 mb-3">
                                <label class="form-label fw-medium">Total Marks *</label>
                                <input type="number" name="totalMarks" class="form-control" value="100" min="1" max="1000" required>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-circle me-1"></i>Create</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Search students
        document.getElementById('rosterSearch')?.addEventListener('input', function() {
            const f = this.value.toLowerCase();
            document.querySelectorAll('.student-row').forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(f) ? '' : 'none';
            });
        });

        // Save grade via AJAX
        document.querySelectorAll('.save-grade-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                const studentId = this.dataset.student;
                const row = document.getElementById('student-row-' + studentId);
                const grade = row.querySelector('.grade-select').value;
                const marks = row.querySelector('.marks-input').value;
                const statusEl = document.getElementById('status-' + studentId);

                if (!grade) { alert('Please select a grade'); return; }

                this.disabled = true;
                this.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

                fetch('/faculty/courses/<%= course._id %>/grade', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ studentId, grade, marks })
                })
                .then(r => r.json())
                .then(data => {
                    if (data.success) {
                        statusEl.innerHTML = '<i class="bi bi-check-circle-fill text-success"></i>';
                        setTimeout(() => statusEl.innerHTML = '', 3000);
                    } else {
                        alert(data.error || 'Failed');
                    }
                    this.disabled = false;
                    this.innerHTML = '<i class="bi bi-check2"></i> Save';
                })
                .catch(() => {
                    alert('Error saving grade');
                    this.disabled = false;
                    this.innerHTML = '<i class="bi bi-check2"></i> Save';
                });
            });
        });
    </script>
</body>
</html>
