<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow" style="max-width: 440px; width: 100%;">
        <div class="card-body p-4">

            <div class="text-center mb-4">
                <div style="width:60px;height:60px;border-radius:50%;background:linear-gradient(135deg,#4f8cff,#6c5ce7);display:inline-flex;align-items:center;justify-content:center;margin-bottom:12px;">
                    <i class="bi bi-lock-fill text-white" style="font-size:1.5rem;"></i>
                </div>
                <h2 class="mb-1">Forgot Password?</h2>
                <p class="text-muted" style="font-size:0.9rem;">Enter your registered email to reset your password.</p>
            </div>

            <% if (locals.error) { %>
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-circle me-1"></i> <%= error %>
                </div>
            <% } %>

            <form action="/auth/forgot-password" method="POST">
                <div class="mb-3">
                    <label class="form-label fw-medium">Email Address</label>
                    <input type="email" name="email" class="form-control form-control-lg"
                           placeholder="you@example.com"
                           value="<%= locals.old ? old.email || '' : '' %>" required>
                    <div class="form-text">Enter the email you used to sign up.</div>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2">
                    <i class="bi bi-arrow-right me-1"></i> Continue
                </button>
            </form>

            <p class="text-center mt-3 mb-0">
                <a href="/auth/login" class="text-decoration-none">
                    <i class="bi bi-arrow-left me-1"></i> Back to Login
                </a>
            </p>

        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
