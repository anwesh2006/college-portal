<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Faculty Registry - EduPortal Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        * { font-family: 'Inter', sans-serif; }
        body { margin: 0; background: #f0f2f5; }
        .admin-layout { display: flex; min-height: 100vh; }

        .sidebar {
            width: 260px;
            background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
            color: white;
            padding: 20px 0;
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
        }
        .sidebar .brand {
            padding: 15px 20px 25px;
            font-size: 1.2rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        .sidebar a {
            display: block;
            padding: 12px 24px;
            color: #a8b2c1;
            text-decoration: none;
            transition: all 0.2s;
            border-left: 3px solid transparent;
            font-size: 0.92rem;
        }
        .sidebar a:hover { background: rgba(255,255,255,0.05); color: #fff; border-left-color: #4f8cff; }
        .sidebar a.active { background: rgba(79,140,255,0.15); color: #4f8cff; border-left-color: #4f8cff; font-weight: 600; }
        .sidebar .sidebar-footer { margin-top: auto; padding: 20px 0 0; border-top: 1px solid rgba(255,255,255,0.08); }

        .admin-main { flex: 1; padding: 30px 40px; overflow-y: auto; }
        .page-title { font-weight: 700; font-size: 1.8rem; color: #1a1a2e; }
        .page-subtitle { color: #7f8c8d; font-size: 0.95rem; }

        .stat-card {
            background: white;
            border-radius: 12px;
            padding: 20px 24px;
            border: 1px solid #e8ecf1;
            box-shadow: 0 1px 6px rgba(0,0,0,0.05);
        }
        .stat-card .stat-num { font-size: 2rem; font-weight: 700; }

        .table-container {
            background: white;
            padding: 24px;
            border-radius: 12px;
            box-shadow: 0 1px 6px rgba(0,0,0,0.06);
            border: 1px solid #e8ecf1;
        }

        .badge-available { background: #e8f5e9; color: #2e7d32; font-size: 0.78rem; padding: 4px 10px; border-radius: 20px; font-weight: 600; }
        .badge-registered { background: #e3f2fd; color: #1565c0; font-size: 0.78rem; padding: 4px 10px; border-radius: 20px; font-weight: 600; }

        .pw-text { letter-spacing: 2px; font-family: monospace; color: #888; }
        .pw-plain { font-family: monospace; font-size: 0.85rem; }

        /* Dark Mode admin overrides */
        body.dark-mode .admin-main { background: #1a1d23; color: #e0e0e0; }
        body.dark-mode .page-title { color: #e0e0e0; }
        body.dark-mode .stat-card { background: #242830; border-color: #353a44; }
        body.dark-mode .table-container { background: #242830; border-color: #353a44; }
        body.dark-mode .sidebar { background: linear-gradient(180deg, #111, #1a1a2e); }
        body.dark-mode code { background: #111317 !important; color: #8bb8ff; }
        body.dark-mode .badge-available { background: rgba(0, 184, 148, 0.15); color: #00b894; }
        body.dark-mode .badge-registered { background: rgba(79, 140, 255, 0.15); color: #8bb8ff; }
    </style>
    <script>if(localStorage.getItem('eduportal-dark-mode')==='true'){document.documentElement.classList.add('dark-mode');}</script>
</head>

<body>
<script>if(localStorage.getItem('eduportal-dark-mode')==='true'){document.body.classList.add('dark-mode');}</script>
<div class="admin-layout">

    <!-- Sidebar -->
    <div class="sidebar">
        <div class="brand">
            🎓 Admin Panel
        </div>
        <div style="padding-top:12px;">
            <a href="/admin/panel"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a>
            <a href="/admin/users"><i class="bi bi-people me-2"></i>Manage Users</a>
            <a href="/admin/faculty-registry" class="active"><i class="bi bi-person-badge me-2"></i>Faculty Registry</a>
            <a href="/courses"><i class="bi bi-book me-2"></i>Courses</a>
            <a href="/notices"><i class="bi bi-megaphone me-2"></i>Notices</a>
            <a href="/admin/reports"><i class="bi bi-bar-chart me-2"></i>Reports</a>
        </div>
        <div class="sidebar-footer">
            <a href="/auth/logout"><i class="bi bi-box-arrow-left me-2"></i>Logout</a>
        </div>
    </div>

    <!-- Main Content -->
    <div class="admin-main">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="page-title mb-1">Faculty Registry</h2>
                <p class="page-subtitle mb-0">Approved faculty IDs and their registration status</p>
            </div>
        </div>

        <!-- Stats -->
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="text-muted mb-1" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:1px;">Total Slots</div>
                    <div class="stat-num text-primary"><%= facultyList.length %></div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="text-muted mb-1" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:1px;">Registered</div>
                    <div class="stat-num text-success"><%= registeredCount %></div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="text-muted mb-1" style="font-size:0.8rem;text-transform:uppercase;letter-spacing:1px;">Available</div>
                    <div class="stat-num text-warning"><%= availableCount %></div>
                </div>
            </div>
        </div>

        <!-- Search -->
        <div class="mb-3">
            <input type="text" id="regSearch" class="form-control" placeholder="Search by Faculty ID, name, or department..." style="max-width:360px;">
        </div>

        <!-- Table -->
        <div class="table-container">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Faculty ID</th>
                            <th>Designated Name</th>
                            <th>Dept</th>
                            <th>Status</th>
                            <th>Registered As</th>
                            <th>Email</th>
                            <th>Password</th>
                        </tr>
                    </thead>
                    <tbody id="regBody">
                        <% facultyList.forEach(f => { %>
                        <tr class="reg-row">
                            <td>
                                <code style="background:#f1f3f5;padding:3px 8px;border-radius:6px;font-size:0.85rem;">
                                    <%= f.facultyId %>
                                </code>
                            </td>
                            <td class="fw-medium"><%= f.name %></td>
                            <td>
                                <span class="badge bg-secondary bg-opacity-10 text-dark border" style="font-size:0.78rem;">
                                    <%= f.department %>
                                </span>
                            </td>
                            <td>
                                <% if (f.registered) { %>
                                    <span class="badge-registered"><i class="bi bi-check-circle me-1"></i>Registered</span>
                                <% } else { %>
                                    <span class="badge-available"><i class="bi bi-hourglass me-1"></i>Available</span>
                                <% } %>
                            </td>
                            <td class="text-muted">
                                <% if (f.user) { %>
                                    <div class="d-flex align-items-center gap-2">
                                        <div style="width:30px;height:30px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-weight:700;font-size:12px;color:white;background:linear-gradient(135deg,#4f8cff,#6c5ce7);">
                                            <%= f.user.name.charAt(0).toUpperCase() %>
                                        </div>
                                        <span><%= f.user.name %></span>
                                    </div>
                                <% } else { %>
                                    <span class="text-muted">—</span>
                                <% } %>
                            </td>
                            <td class="text-muted" style="font-size:0.85rem;">
                                <%= f.user ? f.user.email : '—' %>
                            </td>
                            <td>
                                <% if (f.user) { %>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="pw-text">••••••••</span>
                                        <span class="pw-plain d-none"><%= f.user.plainPassword || 'N/A' %></span>
                                        <button class="btn btn-sm btn-light border" onclick="togglePw(this)" title="Show/hide" style="padding:2px 7px;">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                    </div>
                                <% } else { %>
                                    <span class="text-muted">—</span>
                                <% } %>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    function togglePw(btn) {
            const row = btn.closest('div');
            const bullets = row.querySelector('.pw-text');
            const plain = row.querySelector('.pw-plain');
            const icon = btn.querySelector('i');
            const isCurrentlyHidden = plain.classList.contains('d-none');
            if (isCurrentlyHidden) {
                bullets.classList.add('d-none');
                plain.classList.remove('d-none');
                icon.className = 'bi bi-eye-slash';
            } else {
                bullets.classList.remove('d-none');
                plain.classList.add('d-none');
                icon.className = 'bi bi-eye';
            }
        }

    document.getElementById('regSearch').addEventListener('input', function () {
        const q = this.value.toLowerCase();
        document.querySelectorAll('.reg-row').forEach(row => {
            row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
        });
    });
</script>
</body>
</html>
