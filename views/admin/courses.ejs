<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Courses - EduPortal Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        * { font-family: 'Inter', sans-serif; }
        body { margin: 0; background: #f0f2f5; }
        .admin-layout { display: flex; min-height: 100vh; }

        .sidebar {
            width: 260px;
            background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
            color: white;
            padding: 20px 0;
            display: flex;
            flex-direction: column;
        }
        .sidebar .brand {
            padding: 15px 20px 25px;
            font-size: 1.2rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        .sidebar a {
            display: block; padding: 12px 24px; color: #a8b2c1;
            text-decoration: none; transition: all 0.2s;
            border-left: 3px solid transparent; font-size: 0.92rem;
        }
        .sidebar a:hover { background: rgba(255,255,255,0.05); color: #fff; border-left-color: #4f8cff; }
        .sidebar a.active { background: rgba(79,140,255,0.15); color: #4f8cff; border-left-color: #4f8cff; font-weight: 600; }

        .admin-main { flex: 1; padding: 30px 40px; overflow-y: auto; }
        .page-title { font-weight: 700; font-size: 1.8rem; color: #1a1a2e; }
        .page-subtitle { color: #7f8c8d; font-size: 0.95rem; }

        .course-card-item {
            background: white;
            border: 1px solid #e8ecf1;
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 1px 6px rgba(0,0,0,0.06);
            transition: transform 0.15s, box-shadow 0.15s;
            height: 100%;
        }
        .course-card-item:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(0,0,0,0.08);
        }

        /* Dark Mode */
        body.dark-mode { background: #111317; }
        body.dark-mode .admin-main { background: #1a1d23; color: #e0e0e0; }
        body.dark-mode .page-title { color: #e0e0e0; }
        body.dark-mode .page-subtitle { color: #9aa0ac; }
        body.dark-mode .course-card-item { background: #242830; border-color: #353a44; color: #e0e0e0; }
        body.dark-mode .course-card-item:hover { box-shadow: 0 6px 18px rgba(0,0,0,0.2); }
        body.dark-mode .course-card-item h5 { color: #e0e0e0; }
        body.dark-mode .sidebar { background: linear-gradient(180deg, #111, #1a1a2e); }
        body.dark-mode .modal-content { background: #242830; color: #e0e0e0; border-color: #353a44; }
        body.dark-mode .modal-header { border-color: #353a44; }
        body.dark-mode .modal-footer { border-color: #353a44; }
        body.dark-mode .form-control, body.dark-mode .form-select { background: #1a1d23; color: #e0e0e0; border-color: #353a44; }
        body.dark-mode .form-control:focus, body.dark-mode .form-select:focus { background: #1a1d23; color: #e0e0e0; border-color: #4f8cff; }
        body.dark-mode .form-label { color: #ccc; }
        body.dark-mode .btn-close { filter: invert(1); }
    </style>
    <script>if(localStorage.getItem('eduportal-dark-mode')==='true'){document.documentElement.classList.add('dark-mode');}</script>
</head>

<body>
<script>if(localStorage.getItem('eduportal-dark-mode')==='true'){document.body.classList.add('dark-mode');}</script>
    <div class="admin-layout">
        <%- include('partials/sidebar', { activePage: 'courses' }) %>

            <div class="admin-main">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="page-title mb-1">Courses</h2>
                        <p class="page-subtitle mb-0"><%= courses.length %> active courses</p>
                    </div>
                    <div class="d-flex gap-2 align-items-center">
                        <input type="text" class="form-control" id="courseSearch" placeholder="Search courses..."
                            style="width: 250px;">
                        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addCourseModal" style="white-space:nowrap">
                            <i class="bi bi-plus-lg me-1"></i>Add Course
                        </button>
                    </div>
                </div>

                <div class="row g-3" id="coursesGrid">
                    <% courses.forEach(function(course) { %>
                        <div class="col-md-6 col-lg-4 course-card" data-title="<%= course.title.toLowerCase() %>" data-dept="<%= course.department.toLowerCase() %>">
                            <div class="course-card-item">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h5 class="fw-bold mb-0"><%= course.title %></h5>
                                    <span class="badge bg-secondary"><%= course.code %></span>
                                </div>
                                <p class="text-muted mb-2" style="font-size:0.85rem">
                                    <i class="bi bi-person me-1"></i><%= course.facultyId && course.facultyId.name ? course.facultyId.name : 'TBA' %>
                                </p>
                                <div class="d-flex gap-3 mb-2" style="font-size:0.85rem">
                                    <span><strong>Credits:</strong> <%= course.credits %></span>
                                    <span><strong>Dept:</strong> <%= course.department %></span>
                                </div>
                                <div class="mb-3" style="font-size:0.85rem">
                                    <strong>Slots:</strong>
                                    <% var remaining = course.totalSlots - (course.enrolledCount || 0); %>
                                    <span class="<%= remaining <= 5 ? 'text-danger fw-bold' : 'text-success' %>">
                                        <%= remaining %> / <%= course.totalSlots %>
                                    </span>
                                </div>
                                <div>
                                    <form action="/courses/<%= course._id %>?_method=DELETE"
                                        method="POST" style="display:inline"
                                        onsubmit="return confirm('Delete this course?')">
                                        <button class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash me-1"></i>Delete
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                </div>

                <% if (courses.length === 0) { %>
                    <div class="text-center py-5">
                        <i class="bi bi-book" style="font-size: 3rem; color: #ccc;"></i>
                        <p class="text-muted mt-2">No courses yet. Add your first one!</p>
                    </div>
                <% } %>
            </div>
    </div>

    <!-- Add Course Modal -->
    <div class="modal fade" id="addCourseModal" tabindex="-1" aria-labelledby="addCourseModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius:14px;overflow:hidden">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold" id="addCourseModalLabel"><i class="bi bi-book me-2"></i>Add New Course</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form action="/courses" method="POST">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Title <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="title" required placeholder="e.g. Data Structures">
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-6">
                                <label class="form-label">Code <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" name="code" required placeholder="e.g. CS201">
                            </div>
                            <div class="col-6">
                                <label class="form-label">Credits <span class="text-danger">*</span></label>
                                <input type="number" class="form-control" name="credits" required min="1" max="6" value="3">
                            </div>
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-6">
                                <label class="form-label">Department <span class="text-danger">*</span></label>
                                <select class="form-select" name="department" required>
                                    <option value="CS">Computer Science</option>
                                    <option value="EC">Electronics</option>
                                    <option value="ME">Mechanical</option>
                                    <option value="CE">Civil</option>
                                    <option value="EE">Electrical</option>
                                    <option value="IT">Info Technology</option>
                                    <option value="BT">Biotechnology</option>
                                    <option value="CH">Chemical</option>
                                </select>
                            </div>
                            <div class="col-6">
                                <label class="form-label">Total Slots</label>
                                <input type="number" class="form-control" name="totalSlots" min="1" value="60">
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" name="description" rows="2" placeholder="Brief description..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Create Course</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Search filter
        document.getElementById('courseSearch').addEventListener('input', function() {
            var filter = this.value.toLowerCase();
            document.querySelectorAll('.course-card').forEach(function(card) {
                var title = card.getAttribute('data-title');
                var dept = card.getAttribute('data-dept');
                card.style.display = (title.includes(filter) || dept.includes(filter)) ? '' : 'none';
            });
        });
    </script>
</body>

</html>
