<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reports - EduPortal Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        * {
            font-family: 'Inter', sans-serif;
        }

        body {
            margin: 0;
            background: #f0f2f5;
        }

        .admin-layout {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 260px;
            background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
            color: white;
            padding: 20px 0;
            display: flex;
            flex-direction: column;
        }

        .sidebar .brand {
            padding: 15px 20px 25px;
            font-size: 1.2rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .sidebar a {
            display: block;
            padding: 12px 24px;
            color: #a8b2c1;
            text-decoration: none;
            transition: all 0.2s;
            border-left: 3px solid transparent;
            font-size: 0.92rem;
        }

        .sidebar a:hover {
            background: rgba(255, 255, 255, 0.05);
            color: #fff;
            border-left-color: #4f8cff;
        }

        .sidebar a.active {
            background: rgba(79, 140, 255, 0.15);
            color: #4f8cff;
            border-left-color: #4f8cff;
            font-weight: 600;
        }

        .admin-main {
            flex: 1;
            padding: 30px 40px;
            overflow-y: auto;
        }

        .report-card {
            background: white;
            padding: 28px;
            border-radius: 12px;
            box-shadow: 0 1px 6px rgba(0, 0, 0, 0.06);
            border: 1px solid #e8ecf1;
            margin-bottom: 28px;
        }

        .page-title {
            font-weight: 700;
            font-size: 1.8rem;
            color: #1a1a2e;
        }

        .page-subtitle {
            color: #7f8c8d;
            font-size: 0.95rem;
        }

        .bar-chart .bar-row {
            display: flex;
            align-items: center;
            margin-bottom: 12px;
        }

        .bar-chart .bar-label {
            width: 200px;
            font-size: 0.9rem;
            font-weight: 500;
            color: #333;
            flex-shrink: 0;
        }

        .bar-chart .bar-fill {
            height: 28px;
            border-radius: 6px;
            min-width: 30px;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding-right: 10px;
            color: white;
            font-size: 0.8rem;
            font-weight: 600;
            transition: width 0.6s ease;
        }

        .bar-chart .bar-container {
            flex: 1;
            background: #f0f2f5;
            border-radius: 6px;
            overflow: hidden;
        }
        /* Dark Mode admin overrides */
        body.dark-mode { background: #111317; }
        body.dark-mode .admin-main { background: #1a1d23; color: #e0e0e0; }
        body.dark-mode .page-title { color: #e0e0e0; }
        body.dark-mode .page-subtitle { color: #9aa0ac; }
        body.dark-mode .report-card { background: #242830; border-color: #353a44; }
        body.dark-mode .report-card h5 { color: #e0e0e0; }
        body.dark-mode .sidebar { background: linear-gradient(180deg, #111, #1a1a2e); }
        body.dark-mode .bar-chart .bar-label { color: #e0e0e0; }
        body.dark-mode .bar-chart .bar-container { background: #111317; }
        body.dark-mode .dept-label { color: #9aa0ac; }
    </style>
    <script>if(localStorage.getItem('eduportal-dark-mode')==='true'){document.documentElement.classList.add('dark-mode');}</script>
</head>

<body>
<script>if(localStorage.getItem('eduportal-dark-mode')==='true'){document.body.classList.add('dark-mode');}</script>
    <div class="admin-layout">
        <%- include('partials/sidebar', { activePage: 'reports' }) %>

            <div class="admin-main">
                <h2 class="page-title mb-1">Reports & Analytics</h2>
                <p class="page-subtitle mb-4">Enrollment and student statistics</p>

                <!-- Enrollments by Course -->
                <div class="report-card">
                    <h5 class="fw-bold mb-4"><i class="bi bi-bar-chart me-2"></i>Enrollments by Course</h5>
                    <% if (enrollmentsByCourse && enrollmentsByCourse.length !== 0) { %>
                        <% var maxEnroll = Math.max.apply(null, enrollmentsByCourse.map(function(e){ return e.count })); %>
                        <% var barColors = ['#4f8cff','#6c5ce7','#00b894','#fdcb6e','#e17055','#0984e3','#a29bfe','#55efc4']; %>
                            <div class="bar-chart">
                                <% enrollmentsByCourse.forEach(function(item, i) { %>
                                        <div class="bar-row">
                                            <div class="bar-label">
                                                <%= item.courseName || 'Unknown' %>
                                            </div>
                                            <div class="bar-container">
                                                <% var barW = Math.max((item.count / maxEnroll) * 100, 10); %>
                                                <% var barStyle = 'width:' + barW + '%;background:' + barColors[i % barColors.length]; %>
                                                <div class="bar-fill" style="<%- barStyle %>">
                                                    <%= item.count %>
                                                </div>
                                            </div>
                                        </div>
                                <% }); %>
                            </div>
                            <% } else { %>
                                <div class="text-center text-muted py-4">
                                    <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                                    <p class="mt-2">No enrollment data yet</p>
                                </div>
                                <% } %>
                </div>

                <!-- Students by Department -->
                <div class="report-card">
                    <h5 class="fw-bold mb-4"><i class="bi bi-people me-2"></i>Students by Department</h5>
                    <% if (studentsByDept && studentsByDept.length !== 0) { %>
                        <% var deptColors = { CS:'#4f8cff', EC:'#6c5ce7', ME:'#e17055', CE:'#00b894', EE:'#fdcb6e', IT:'#0984e3', BT:'#a29bfe', CH:'#55efc4' }; %>
                        <% var deptNames = { CS:'Computer Science', EC:'Electronics', ME:'Mechanical', CE:'Civil', EE:'Electrical', IT:'Info Technology', BT:'Biotechnology', CH:'Chemical' }; %>
                        <div class="row g-3">
                                    <% studentsByDept.forEach(function(dept) { %>
                                        <div class="col-md-4 col-lg-3">
                                            <% var clr = deptColors[dept.department] || '#95a5a6'; %>
                                            <% var cardStyle = 'background:' + clr + '15;border:1px solid ' + clr + '30'; %>
                                            <% var numStyle = 'font-size:2rem;font-weight:700;color:' + clr; %>
                                            <div class="text-center p-3 rounded-3" style="<%- cardStyle %>">
                                                <div style="<%- numStyle %>">
                                                    <%= dept.count %>
                                                </div>
                                                <div class="dept-label" style="font-size:0.85rem;font-weight:500">
                                                    <%= deptNames[dept.department] || dept.department %>
                                                </div>
                                            </div>
                                        </div>
                                    <% }); %>
                        </div>
                        <% } else { %>
                            <div class="text-center text-muted py-4">
                                <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                                <p class="mt-2">No student data yet</p>
                            </div>
                            <% } %>
                </div>
            </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>