<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Users - EduPortal Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <style>
        * {
            font-family: 'Inter', sans-serif;
        }

        body {
            margin: 0;
            background: #f0f2f5;
        }

        .admin-layout {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 260px;
            background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
            color: white;
            padding: 20px 0;
            display: flex;
            flex-direction: column;
        }

        .sidebar .brand {
            padding: 15px 20px 25px;
            font-size: 1.2rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .sidebar a {
            display: block;
            padding: 12px 24px;
            color: #a8b2c1;
            text-decoration: none;
            transition: all 0.2s;
            border-left: 3px solid transparent;
            font-size: 0.92rem;
        }

        .sidebar a:hover {
            background: rgba(255, 255, 255, 0.05);
            color: #fff;
            border-left-color: #4f8cff;
        }

        .sidebar a.active {
            background: rgba(79, 140, 255, 0.15);
            color: #4f8cff;
            border-left-color: #4f8cff;
            font-weight: 600;
        }

        .admin-main {
            flex: 1;
            padding: 30px 40px;
            overflow-y: auto;
        }

        .table-container {
            background: white;
            padding: 28px;
            border-radius: 12px;
            box-shadow: 0 1px 6px rgba(0, 0, 0, 0.06);
            border: 1px solid #e8ecf1;
        }

        .page-title {
            font-weight: 700;
            font-size: 1.8rem;
            color: #1a1a2e;
        }

        .page-subtitle {
            color: #7f8c8d;
            font-size: 0.95rem;
        }
        /* Dark Mode admin overrides */
        body.dark-mode .admin-main { background: #1a1d23; color: #e0e0e0; }
        body.dark-mode .page-title { color: #e0e0e0; }
        body.dark-mode .stat-card { background: #242830; border-color: #353a44; }
        body.dark-mode .table-container { background: #242830; border-color: #353a44; }
        body.dark-mode .sidebar { background: linear-gradient(180deg, #111, #1a1a2e); }
        body.dark-mode .password-toggle-btn { color: #8bb8ff; background: rgba(79, 140, 255, 0.1); }
        body.dark-mode .password-toggle-btn:hover { background: rgba(79, 140, 255, 0.2); }
        body.dark-mode .modal-content { background: #242830; color: #e0e0e0; border-color: #353a44; }
        body.dark-mode .modal-header { border-color: #353a44; }
        body.dark-mode .modal-footer { border-color: #353a44; }
        body.dark-mode .form-control, body.dark-mode .form-select { background: #1a1d23; color: #e0e0e0; border-color: #353a44; }
        body.dark-mode .form-control:focus, body.dark-mode .form-select:focus { background: #1a1d23; color: #e0e0e0; border-color: #4f8cff; box-shadow: 0 0 0 0.2rem rgba(79,140,255,0.2); }
        body.dark-mode .form-label { color: #ccc; }
        body.dark-mode .btn-close { filter: invert(1); }
        .student-fields { display: none; }
    </style>
    <script>if(localStorage.getItem('eduportal-dark-mode')==='true'){document.documentElement.classList.add('dark-mode');}</script>
</head>

<body>
<script>if(localStorage.getItem('eduportal-dark-mode')==='true'){document.body.classList.add('dark-mode');}</script>
    <div class="admin-layout">
        <%- include('partials/sidebar', { activePage: 'users' }) %>

            <div class="admin-main">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="page-title mb-1">Manage Users</h2>
                        <p class="page-subtitle mb-0">
                            <%= total %> total users
                        </p>
                    </div>
                    <div class="d-flex gap-2 align-items-center">
                        <input type="text" class="form-control" id="userSearch" placeholder="Search users..."
                            style="width: 250px;">
                        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addUserModal" style="white-space:nowrap">
                            <i class="bi bi-person-plus me-1"></i>Add User
                        </button>
                    </div>
                </div>

                <div class="table-container">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Role</th>
                                    <th>Password</th>
                                    <th>Joined</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody id="usersTableBody">
                                <% users.forEach(u=> { %>
                                    <tr id="user-<%= u._id %>" class="user-row">
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div
                                                    style="width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:600;font-size:14px;color:white;background:linear-gradient(135deg,#4f8cff,#6c5ce7);">
                                                    <%= u.name ? u.name.charAt(0).toUpperCase() : '?' %>
                                                </div>
                                                <span class="fw-medium user-name">
                                                    <%= u.name %>
                                                </span>
                                            </div>
                                        </td>
                                        <td class="text-muted user-email">
                                            <%= u.email %>
                                        </td>
                                        <td>
                                            <select class="form-select form-select-sm" style="width:120px;"
                                                onchange="updateRole('<%= u._id %>', this.value)">
                                                <option value="student" <%=u.role==='student' ? 'selected' : '' %>
                                                    >Student</option>
                                                <option value="faculty" <%=u.role==='faculty' ? 'selected' : '' %>
                                                    >Faculty</option>
                                                <option value="admin" <%=u.role==='admin' ? 'selected' : '' %>>Admin
                                                </option>
                                            </select>
                                        </td>
                                         <td>
                                             <% if (u.plainPassword) { %>
                                             <div class="d-flex align-items-center gap-1">
                                                 <span class="pw-text text-muted" style="letter-spacing:2px;font-family:monospace;font-size:0.9rem;">••••••••</span>
                                                 <span class="pw-plain d-none text-dark fw-medium" style="font-family:monospace;font-size:0.85rem;"><%= u.plainPassword %></span>
                                                 <button class="btn btn-sm btn-light border" onclick="togglePw(this)" title="Show / Hide password" style="padding:2px 7px;">
                                                     <i class="bi bi-eye"></i>
                                                 </button>
                                                 <button class="btn btn-sm btn-light border pw-copy d-none" onclick="copyPw(this)" title="Copy password" style="padding:2px 7px;">
                                                     <i class="bi bi-clipboard"></i>
                                                 </button>
                                             </div>
                                             <% } else { %>
                                             <span class="text-muted" style="font-size:0.8rem;" title="Password was not tracked — user signed up before tracking was enabled">
                                                 <i class="bi bi-lock text-secondary me-1"></i>Not stored
                                             </span>
                                             <% } %>
                                         </td>
                                         <td class="text-muted">
                                             <%= u.createdAt ? new Date(u.createdAt).toLocaleDateString() : 'N/A' %>
                                         </td>
                                        <td>
                                            <button class="btn btn-sm btn-outline-danger"
                                                onclick="deleteUser('<%= u._id %>', '<%= u.name %>')">
                                                <i class="bi bi-trash me-1"></i>Delete
                                            </button>
                                        </td>
                                    </tr>
                                    <% }); %>
                                        <% if (users.length===0) { %>
                                            <tr>
                                                <td colspan="6" class="text-center text-muted py-4">No users found.</td>
                                            </tr>
                                            <% } %>
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination -->
                    <% if (pages> 1) { %>
                        <nav class="mt-4">
                            <ul class="pagination justify-content-center mb-0">
                                <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
                                    <a class="page-link" href="/admin/users?page=<%= page - 1 %>">Previous</a>
                                </li>
                                <% for (let i=1; i <=pages; i++) { %>
                                    <li class="page-item <%= i === page ? 'active' : '' %>">
                                        <a class="page-link" href="/admin/users?page=<%= i %>">
                                            <%= i %>
                                        </a>
                                    </li>
                                    <% } %>
                                        <li class="page-item <%= page >= pages ? 'disabled' : '' %>">
                                            <a class="page-link" href="/admin/users?page=<%= page + 1 %>">Next</a>
                                        </li>
                            </ul>
                        </nav>
                        <% } %>
                </div>
            </div>
    </div>

    <!-- Add User Modal -->
    <div class="modal fade" id="addUserModal" tabindex="-1" aria-labelledby="addUserModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius:14px;overflow:hidden">
                <div class="modal-header" style="border-bottom:1px solid #e8ecf1">
                    <h5 class="modal-title fw-bold" id="addUserModalLabel"><i class="bi bi-person-plus me-2"></i>Add New User</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div id="addUserError" class="alert alert-danger d-none" role="alert"></div>
                    <div id="addUserSuccess" class="alert alert-success d-none" role="alert"></div>
                    <form id="addUserForm">
                        <div class="mb-3">
                            <label for="newName" class="form-label">Full Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="newName" required placeholder="e.g. John Doe">
                        </div>
                        <div class="mb-3">
                            <label for="newEmail" class="form-label">Email <span class="text-danger">*</span></label>
                            <input type="email" class="form-control" id="newEmail" required placeholder="e.g. john@example.com">
                        </div>
                        <div class="mb-3">
                            <label for="newPassword" class="form-label">Password <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="newPassword" required placeholder="Enter password">
                        </div>
                        <div class="mb-3">
                            <label for="newRole" class="form-label">Role <span class="text-danger">*</span></label>
                            <select class="form-select" id="newRole">
                                <option value="student" selected>Student</option>
                                <option value="faculty">Faculty</option>
                                <option value="admin">Admin</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="newDept" class="form-label">Department</label>
                            <select class="form-select" id="newDept">
                                <option value="">— Select —</option>
                                <option value="CS">Computer Science</option>
                                <option value="EC">Electronics</option>
                                <option value="ME">Mechanical</option>
                                <option value="CE">Civil</option>
                                <option value="EE">Electrical</option>
                                <option value="IT">Info Technology</option>
                                <option value="BT">Biotechnology</option>
                                <option value="CH">Chemical</option>
                            </select>
                        </div>
                        <div class="student-fields" id="studentFields">
                            <div class="mb-3">
                                <label for="newRoll" class="form-label">Roll Number</label>
                                <input type="text" class="form-control" id="newRoll" placeholder="e.g. CS-2026-001">
                            </div>
                            <div class="mb-3">
                                <label for="newSemester" class="form-label">Semester</label>
                                <select class="form-select" id="newSemester">
                                    <option value="1">1</option>
                                    <option value="2">2</option>
                                    <option value="3">3</option>
                                    <option value="4">4</option>
                                    <option value="5">5</option>
                                    <option value="6">6</option>
                                    <option value="7">7</option>
                                    <option value="8">8</option>
                                </select>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer" style="border-top:1px solid #e8ecf1">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="submitAddUser" onclick="createUser()">
                        <i class="bi bi-check-lg me-1"></i>Create User
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function togglePw(btn) {
            const row = btn.closest('div');
            const bullets = row.querySelector('.pw-text');
            const plain = row.querySelector('.pw-plain');
            const copyBtn = row.querySelector('.pw-copy');
            const icon = btn.querySelector('i');
            // Check current state: is password currently hidden?
            const isCurrentlyHidden = !plain.classList.contains('d-none') === false;
            if (isCurrentlyHidden) {
                // Show password
                bullets.classList.add('d-none');
                plain.classList.remove('d-none');
                if (copyBtn) copyBtn.classList.remove('d-none');
                icon.className = 'bi bi-eye-slash';
            } else {
                // Hide password
                bullets.classList.remove('d-none');
                plain.classList.add('d-none');
                if (copyBtn) copyBtn.classList.add('d-none');
                icon.className = 'bi bi-eye';
            }
        }

        function copyPw(btn) {
            const row = btn.closest('div');
            const plain = row.querySelector('.pw-plain');
            if (!plain) return;
            navigator.clipboard.writeText(plain.textContent.trim()).then(() => {
                const icon = btn.querySelector('i');
                icon.className = 'bi bi-clipboard-check text-success';
                setTimeout(() => icon.className = 'bi bi-clipboard', 1500);
            });
        }

        // Client-side search
        document.getElementById('userSearch')?.addEventListener('input', function () {
            const filter = this.value.toLowerCase();
            document.querySelectorAll('.user-row').forEach(row => {
                const name = row.querySelector('.user-name')?.textContent.toLowerCase() || '';
                const email = row.querySelector('.user-email')?.textContent.toLowerCase() || '';
                row.style.display = (name.includes(filter) || email.includes(filter)) ? '' : 'none';
            });
        });

        function updateRole(userId, newRole) {
            fetch('/admin/users/' + userId + '/role', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ role: newRole })
            })
                .then(r => r.json())
                .then(data => {
                    if (!data.success) alert(data.error || 'Failed to update role');
                }).catch(() => alert('Error updating role'));
        }

        function deleteUser(userId, name) {
            if (!confirm('Delete "' + name + '"? This cannot be undone.')) return;
            fetch('/admin/users/' + userId, { method: 'DELETE' })
                .then(r => r.json())
                .then(data => {
                    if (data.success) document.getElementById('user-' + userId)?.remove();
                    else alert(data.error || 'Failed');
                }).catch(() => alert('Error'));
        }

        // Toggle student-specific fields based on role
        document.getElementById('newRole').addEventListener('change', function() {
            document.getElementById('studentFields').style.display = this.value === 'student' ? 'block' : 'none';
        });

        function createUser() {
            var errBox = document.getElementById('addUserError');
            var successBox = document.getElementById('addUserSuccess');
            var btn = document.getElementById('submitAddUser');
            errBox.classList.add('d-none');
            successBox.classList.add('d-none');

            var name = document.getElementById('newName').value.trim();
            var email = document.getElementById('newEmail').value.trim();
            var password = document.getElementById('newPassword').value;
            var role = document.getElementById('newRole').value;
            var department = document.getElementById('newDept').value;
            var rollNumber = document.getElementById('newRoll').value.trim();
            var semester = document.getElementById('newSemester').value;

            if (!name || !email || !password) {
                errBox.textContent = 'Name, email, and password are required.';
                errBox.classList.remove('d-none');
                return;
            }

            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Creating...';

            fetch('/admin/users', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ name: name, email: email, password: password, role: role, department: department, rollNumber: rollNumber, semester: semester })
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-check-lg me-1"></i>Create User';
                if (!data.success) {
                    errBox.textContent = data.error || 'Failed to create user.';
                    errBox.classList.remove('d-none');
                    return;
                }
                successBox.textContent = 'User "' + data.user.name + '" created successfully!';
                successBox.classList.remove('d-none');
                document.getElementById('addUserForm').reset();
                document.getElementById('studentFields').style.display = 'block';

                // Insert new row into the table
                var u = data.user;
                var roleBadge = role === 'admin' ? 'bg-danger' : (role === 'faculty' ? 'bg-info text-dark' : 'bg-primary');
                var initial = u.name ? u.name.charAt(0).toUpperCase() : '?';
                var dateStr = new Date(u.createdAt).toLocaleDateString();
                var pwHtml = u.plainPassword
                    ? '<div class="d-flex align-items-center gap-1">'
                        + '<span class="pw-text text-muted" style="letter-spacing:2px;font-family:monospace;font-size:0.9rem">••••••••</span>'
                        + '<span class="pw-plain d-none text-dark fw-medium" style="font-family:monospace;font-size:0.85rem">' + u.plainPassword + '</span>'
                        + '<button class="btn btn-sm btn-light border" onclick="togglePw(this)" title="Show / Hide password" style="padding:2px 7px"><i class="bi bi-eye"></i></button>'
                        + '<button class="btn btn-sm btn-light border pw-copy d-none" onclick="copyPw(this)" title="Copy password" style="padding:2px 7px"><i class="bi bi-clipboard"></i></button>'
                        + '</div>'
                    : '<span class="text-muted" style="font-size:0.8rem"><i class="bi bi-lock text-secondary me-1"></i>Not stored</span>';

                var tr = document.createElement('tr');
                tr.id = 'user-' + u._id;
                tr.className = 'user-row';
                tr.innerHTML = '<td><div class="d-flex align-items-center gap-2">'
                    + '<div style="width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:600;font-size:14px;color:white;background:linear-gradient(135deg,#4f8cff,#6c5ce7)">' + initial + '</div>'
                    + '<span class="fw-medium user-name">' + u.name + '</span></div></td>'
                    + '<td class="text-muted user-email">' + u.email + '</td>'
                    + '<td><select class="form-select form-select-sm" style="width:120px" onchange="updateRole(\'' + u._id + '\', this.value)">'
                        + '<option value="student"' + (u.role==='student'?' selected':'') + '>Student</option>'
                        + '<option value="faculty"' + (u.role==='faculty'?' selected':'') + '>Faculty</option>'
                        + '<option value="admin"' + (u.role==='admin'?' selected':'') + '>Admin</option>'
                    + '</select></td>'
                    + '<td>' + pwHtml + '</td>'
                    + '<td class="text-muted">' + dateStr + '</td>'
                    + '<td><button class="btn btn-sm btn-outline-danger" onclick="deleteUser(\'' + u._id + '\', \'' + u.name.replace(/'/g, "\\'") + '\')"><i class="bi bi-trash me-1"></i>Delete</button></td>';

                var tbody = document.getElementById('usersTableBody');
                if (tbody) tbody.insertBefore(tr, tbody.firstChild);

                // Auto-close modal after 1.5s
                setTimeout(function() {
                    var modal = bootstrap.Modal.getInstance(document.getElementById('addUserModal'));
                    if (modal) modal.hide();
                    successBox.classList.add('d-none');
                }, 1500);
            })
            .catch(function() {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-check-lg me-1"></i>Create User';
                errBox.textContent = 'Network error. Please try again.';
                errBox.classList.remove('d-none');
            });
        }
    </script>
</body>

</html>