<div class="container mt-4">
    <h1 class="mb-4">Available Courses</h1>

    <!-- Search -->
    <div class="mb-4">
        <input type="text" class="form-control" id="courseSearch" placeholder="Search by course title or department...">
    </div>

    <div class="row" id="coursesGrid">
        <% courses.forEach(course => { %>
            <div class="col-md-4 mb-4 course-card" data-title="<%= course.title.toLowerCase() %>"
                data-dept="<%= course.department.toLowerCase() %>">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">
                            <%= course.title %>
                        </h5>
                        <span class="badge bg-secondary mb-2">
                            <%= course.code %>
                        </span>

                        <p><strong>Faculty:</strong>
                            <%= course.facultyId && course.facultyId.name ? course.facultyId.name : 'TBA' %>
                        </p>
                        <p><strong>Credits:</strong>
                            <%= course.credits %>
                        </p>
                        <p><strong>Department:</strong>
                            <%= course.department %>
                        </p>
                        <p><strong>Schedule:</strong>
                            <%= course.schedule || 'TBA' %>
                        </p>
                        <p><strong>Slots Available:</strong>
                            <span class="<%= (course.totalSlots - (course.enrolledCount || 0)) <= 5 ? 'text-danger' : 'text-success' %>">
                                <%= course.totalSlots - (course.enrolledCount || 0) %> / <%= course.totalSlots %>
                            </span>
                        </p>

                        <div class="mt-3">
                            <%/* STUDENT buttons */%>
                            <% if (userRole === 'student') { %>
                                <% if (enrolledCourseIds.includes(course._id.toString())) { %>
                                    <button class="btn btn-success btn-sm" disabled>Enrolled ✓</button>
                                    <button class="btn btn-outline-danger btn-sm drop-btn ms-1" data-id="<%= course._id %>">Drop</button>
                                <% } else if ((course.totalSlots - (course.enrolledCount || 0)) <= 0) { %>
                                    <button class="btn btn-secondary btn-sm" disabled>Full</button>
                                <% } else { %>
                                    <button class="btn btn-primary btn-sm enroll-btn" data-id="<%= course._id %>">Enroll</button>
                                <% } %>
                            <% } %>

                            <%/* ADMIN buttons */%>
                            <% if (userRole === 'admin') { %>
                                <form action="/courses/<%= course._id %>?_method=DELETE"
                                    method="POST" style="display:inline;"
                                    onsubmit="return confirm('Delete this course?')">
                                    <button class="btn btn-danger btn-sm">Delete</button>
                                </form>
                            <% } %>

                            <%/* FACULTY buttons */%>
                            <% if (userRole === 'faculty' && locals.user) { %>
                                <% if (!course.facultyId || !course.facultyId._id) { %>
                                    <button class="btn btn-primary btn-sm claim-btn"
                                        data-id="<%= course._id %>">Claim Course</button>
                                <% } else if (course.facultyId._id && course.facultyId._id.toString() === locals.user._id.toString()) { %>
                                    <a href="/faculty/courses/<%= course._id %>" class="btn btn-success btn-sm">
                                        <i class="bi bi-people me-1"></i>Manage Students
                                    </a>
                                <% } else { %>
                                    <span class="badge bg-light text-muted border">Assigned to other faculty</span>
                                <% } %>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        <% }); %>
    </div>

    <% if (courses.length === 0) { %>
        <div class="text-center py-5">
            <h4>No courses available</h4>
            <p class="text-muted">Courses will appear here once they're added by the administration.</p>
        </div>
    <% } %>
</div>

<script>
    // Search filter
    document.getElementById('courseSearch')?.addEventListener('input', function () {
        const filter = this.value.toLowerCase();
        document.querySelectorAll('.course-card').forEach(card => {
            const title = card.getAttribute('data-title');
            const dept = card.getAttribute('data-dept');
            card.style.display = (title.includes(filter) || dept.includes(filter)) ? '' : 'none';
        });
    });

    // Enroll via AJAX
    document.querySelectorAll('.enroll-btn').forEach(btn => {
        btn.addEventListener('click', function () {
            const courseId = this.getAttribute('data-id');
            this.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Enrolling...';
            this.disabled = true;

            fetch('/courses/' + courseId + '/enroll', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        this.textContent = 'Enrolled ✓';
                        this.classList.remove('btn-primary');
                        this.classList.add('btn-success');
                    } else {
                        alert(data.error || 'Enrollment failed');
                        this.textContent = 'Enroll';
                        this.disabled = false;
                    }
                })
                .catch(() => {
                    alert('Error enrolling. Please try again.');
                    this.textContent = 'Enroll';
                    this.disabled = false;
                });
        });
    });

    // Drop via AJAX
    document.querySelectorAll('.drop-btn').forEach(btn => {
        btn.addEventListener('click', function () {
            if (!confirm('Are you sure you want to drop this course?')) return;
            const courseId = this.getAttribute('data-id');
            this.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Dropping...';
            this.disabled = true;

            fetch('/courses/' + courseId + '/drop', {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' }
            })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert(data.error || 'Failed to drop course');
                        this.textContent = 'Drop';
                        this.disabled = false;
                    }
                })
                .catch(() => {
                    alert('An error occurred');
                    this.textContent = 'Drop';
                    this.disabled = false;
                });
        });
    });

    // Claim via AJAX
    document.querySelectorAll('.claim-btn').forEach(btn => {
        btn.addEventListener('click', function () {
            const courseId = this.getAttribute('data-id');
            this.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Claiming...';
            this.disabled = true;

            fetch('/courses/' + courseId + '/claim', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        this.textContent = 'Claimed ✓';
                        this.classList.replace('btn-primary', 'btn-success');
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        alert(data.error || 'Failed to claim course');
                        this.textContent = 'Claim Course';
                        this.disabled = false;
                    }
                })
                .catch(() => {
                    alert('An error occurred');
                    this.textContent = 'Claim Course';
                    this.disabled = false;
                });
        });
    });
</script>