<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= course.title %> - Enrollment</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .course-header { background-color: #f8f9fa; padding: 2rem 0; margin-bottom: 2rem; }
        .slots-bar { margin: 1rem 0; }
        .enrollment-btn { font-size: 1.1rem; padding: 0.75rem 2rem; }
        .course-meta { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin: 2rem 0; }
        .meta-item { padding: 1rem; background: #f8f9fa; border-radius: 0.5rem; }
        .meta-label { font-weight: 600; color: #495057; font-size: 0.875rem; }
        .meta-value { font-size: 1.1rem; color: #212529; margin-top: 0.5rem; }
    </style>
</head>
<body>
    <div class="container mt-4">
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item"><a href="/courses">Courses</a></li>
                <li class="breadcrumb-item active"><%= course.title %></li>
            </ol>
        </nav>

        <!-- Course Header -->
        <div class="course-header rounded">
            <div class="container">
                <h1><%= course.title %></h1>
                <p class="text-muted"><%= course.code %></p>
            </div>
        </div>

        <div class="row">
            <!-- Main Content -->
            <div class="col-lg-8">
                <!-- Course Details -->
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">Course Description</h5>
                        <p><%= course.description %></p>
                    </div>
                </div>

                <!-- Course Metadata -->
                <div class="course-meta">
                    <div class="meta-item">
                        <div class="meta-label">Department</div>
                        <div class="meta-value"><%= course.department %></div>
                    </div>
                    <div class="meta-item">
                        <div class="meta-label">Faculty</div>
                        <div class="meta-value"><%= course.faculty %></div>
                    </div>
                    <div class="meta-item">
                        <div class="meta-label">Credits</div>
                        <div class="meta-value"><%= course.credits %></div>
                    </div>
                    <div class="meta-item">
                        <div class="meta-label">Schedule</div>
                        <div class="meta-value"><%= course.schedule %></div>
                    </div>
                </div>

                <!-- Slots Remaining -->
                <div class="card mb-4">
                    <div class="card-body">
                        <h5 class="card-title">Availability</h5>
                        <div class="slots-bar">
                            <div class="d-flex justify-content-between mb-2">
                                <span>Slots Remaining</span>
                                <span><strong><%= course.slotsRemaining %> / <%= course.totalSlots %></strong></span>
                            </div>
                            <div class="progress" style="height: 25px;">
                                <div class="progress-bar bg-success" role="progressbar" 
                                     style="width: <%= (course.slotsRemaining / course.totalSlots) * 100 %>%"
                                     aria-valuenow="<%= course.slotsRemaining %>" 
                                     aria-valuemin="0" 
                                     aria-valuemax="<%= course.totalSlots %>">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Related Courses -->
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title mb-4">Related Courses</h5>
                        <div class="row">
                            <% relatedCourses.forEach(relatedCourse => { %>
                                <div class="col-md-6 mb-3">
                                    <div class="card h-100">
                                        <div class="card-body">
                                            <h6 class="card-title"><%= relatedCourse.title %></h6>
                                            <p class="card-text text-muted small"><%= relatedCourse.code %></p>
                                            <p class="card-text small"><%= relatedCourse.description.substring(0, 80) %>...</p>
                                            <a href="/courses/enroll/<%= relatedCourse._id %>" class="btn btn-sm btn-outline-primary">View Course</a>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Enrollment Sidebar -->
            <div class="col-lg-4">
                <div class="card sticky-top" style="top: 20px;">
                    <div class="card-body">
                        <h5 class="card-title">Enrollment</h5>
                        <p class="text-muted small">Course Code: <%= course.code %></p>
                        <p class="text-muted small">Department: <%= course.department %></p>
                        
                        <button id="enrollBtn" class="btn btn-primary enrollment-btn w-100 mt-3">
                            <span id="btnText"><%= isEnrolled ? 'Drop Course' : 'Enroll in this Course' %></span>
                        </button>
                        <small class="text-muted d-block mt-2" id="slotMsg">
                            <% if(course.slotsRemaining === 0) { %>
                                No slots available
                            <% } %>
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const courseId = '<%= course._id %>';
        const isEnrolled = <%= isEnrolled %>;

        document.getElementById('enrollBtn').addEventListener('click', function() {
            const action = isEnrolled ? 'drop' : 'enroll';
            
            fetch(`/courses/${action}/${courseId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    window.location.href = '/student/dashboard';
                } else {
                    alert(data.message || 'An error occurred');
                }
            })
            .catch(err => alert('Error: ' + err.message));
        });
    </script>
</body>
</html>